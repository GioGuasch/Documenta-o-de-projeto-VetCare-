@startuml

entity Usuario {
    * id : BIGINT
    --
    nome : VARCHAR
    email : VARCHAR
    senha : VARCHAR
}

entity Cliente {
    * id : BIGINT
    --
    telefone : VARCHAR
    endereco : VARCHAR
}

entity Animal {
    * id : BIGINT
    --
    nome : VARCHAR
    especie : VARCHAR
    raca : VARCHAR
    idade : INTEGER
    peso : DECIMAL
}

entity Consulta {
    * id : BIGINT
    --
    data_hora : TIMESTAMP
    status : VARCHAR
    valor : DECIMAL
}

entity Prontuario {
    * id : BIGINT
    --
    diagnostico : TEXT
    observacoes : TEXT
}

entity Receita {
    * id : BIGINT
    --
    medicamento : VARCHAR
    dosagem : VARCHAR
}

entity Vacina {
    * id : BIGINT
    --
    nome : VARCHAR
    fabricante : VARCHAR
    data_aplicacao : DATE
}

entity Pagamento {
    * id : BIGINT
    --
    valor : DECIMAL
    status : VARCHAR
}

Cliente ||--o{ Animal

Animal ||--o{ Consulta

Consulta ||--|| Prontuario

Consulta ||--o{ Receita

Animal ||--o{ Vacina

Consulta ||--|| Pagamento

@enduml
